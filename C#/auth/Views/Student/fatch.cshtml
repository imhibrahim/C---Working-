@model IEnumerable<Student>;
<!DOCTYPE html>
    <html>
    <head>
        <title></title>
    </head>
    <body>

        <table class="table">  

            <tr>
                <th>id</th>
                <th>Name</th>
                <th>Mail</th>
                <th>Password</th>
            <th>Standard</th>
            <th>Number</th>
            <th>Action</th>
            </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.id</td>
                <td>@item.name</td>
                <td>@item.mail</td>
                <td>@item.password</td>
                <td>@item.standerd</td>
                <td>@item.number</td>
                <td>
                    <a asp-controller="student" asp-action="details" asp-route-id="@item.id">Details</a>
                    <a asp-controller="student" asp-action="delete" asp-route-id="@item.id">Delete</a>
                    <a asp-controller="student" asp-action="Edit" asp-route-id="@item.id">Edit</a>
                </td>
            </tr>
        }
        </table>
    
    </body>
    </html>